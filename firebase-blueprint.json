{
  "entities": {
    "userSettings": {
      "title": "User Settings",
      "description": "Stores user preferences for Telegram alerts and scanner settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "telegramEnabled": { "type": "boolean" },
        "telegramToken": { "type": "string" },
        "telegramChatId": { "type": "string" },
        "autoScan": { "type": "boolean" },
        "sensitivity": { "type": "number" },
        "multiplier": { "type": "number" },
        "useFilter": { "type": "boolean" },
        "rsiHistLength": { "type": "number" },
        "rsiHistMALength": { "type": "number" },
        "rsiHistMAType": { "type": "string" },
        "rsiSource": { "type": "string" },
        "zigzagLength": { "type": "number" },
        "tpRatio": { "type": "number" },
        "slLookback": { "type": "number" },
        "scanLookbackMinutes": { "type": "number" },
        "binanceKey": { "type": "string" },
        "binanceSecret": { "type": "string" },
        "autoTradeEnabled": { "type": "boolean" },
        "tradeAmount": { "type": "number" },
        "maxOpenTrades": { "type": "number" }
      },
      "required": ["uid"]
    },
    "alerts": {
      "title": "Alerts",
      "description": "Stores triggered alerts to prevent duplicates",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "symbol": { "type": "string" },
        "type": { "type": "string" },
        "timestamp": { "type": "number" },
        "uid": { "type": "string" }
      },
      "required": ["id", "uid"]
    },
    "activityLog": {
      "title": "Activity Log",
      "description": "Stores logs of bot activities and trade attempts",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "symbol": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["INFO", "SUCCESS", "ERROR", "WARNING"] },
        "timestamp": { "type": "number" }
      },
      "required": ["userId", "message", "type", "timestamp"]
    }
  },
  "firestore": {
    "/settings/{uid}": {
      "schema": "userSettings",
      "description": "User specific settings"
    },
    "/alerts/{alertId}": {
      "schema": "alerts",
      "description": "Global or user-specific triggered alerts"
    },
    "/activity/{logId}": {
      "schema": "activityLog",
      "description": "Real-time activity logs for trade status"
    }
  }
}
