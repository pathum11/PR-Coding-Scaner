rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         (request.auth.token.email == "www.pathum.log@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUserSettings(data) {
      return data.uid is string && (request.auth == null || data.uid == request.auth.uid);
    }

    function isValidAlert(data) {
      return data.id is string && data.id.size() < 200 &&
             data.uid is string && (request.auth == null || data.uid == request.auth.uid) &&
             data.symbol is string &&
             data.type is string &&
             data.timestamp is number;
    }

    function isValidActivityLog(data) {
      return data.userId is string && 
             data.message is string && data.message.size() < 1000 &&
             data.type in ["INFO", "SUCCESS", "ERROR", "WARNING"] &&
             data.timestamp is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /activity/{logId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Allow creation for the background scanner (acts as unauthenticated client)
      allow create: if isValidActivityLog(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /settings/{uid} {
      // Diagnostic: Allow read for now to see if scanner works
      allow read: if true; 
      allow create, update: if isOwner(uid) && isValidUserSettings(request.resource.data);
      allow delete: if isAdmin();
    }

    match /alerts/{alertId} {
      // The scanner uses Admin SDK which bypasses these rules.
      // Users can only read their own alerts.
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isOwner(request.resource.data.uid) && isValidAlert(request.resource.data);
      allow update: if isOwner(resource.data.uid) && isValidAlert(request.resource.data) &&
                      request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && 
                            // Prevent self-promotion to admin
                            (request.resource.data.role == (resource == null ? 'user' : resource.data.role) || isAdmin());
    }
  }
}
